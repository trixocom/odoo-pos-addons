<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
        Extensión del receipt POS para mostrar:
        - El plan de cuotas elegido
        - El reintegro del banco cuando aplica

        El plan se resuelve con `getCardPlan(line)` (ver order_receipt.js) desde el
        campo REAL `card_installment_pos_id` de la línea de pago. Antes se leían
        propiedades sueltas (`line.cardPlanName`), pero el POS de Odoo 19 no
        permite asignarlas al record: related_models lanza "The field 'X' does not
        exist in model 'Y'" y deja el POS en blanco.
    -->
    <t t-name="pos_financial_surcharge.OrderReceiptPaymentLine"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('paymentlines')]" position="after">
            <t t-foreach="paymentLines" t-as="line" t-key="'fs_' + line_index">
                <t t-set="plan" t-value="getCardPlan(line)"/>
                <t t-if="plan">
                    <div class="pos-receipt-financial-surcharge text-start" style="font-size: 90%;">
                        <span>
                            <i class="fa fa-credit-card me-1"/>
                            <t t-esc="plan.name"/>
                        </span>
                    </div>
                    <t t-if="plan.bank_discount">
                        <div class="pos-receipt-financial-bank-discount text-start"
                             style="font-size: 90%;">
                            <span>
                                Reintegro banco:
                                <t t-esc="plan.bank_discount"/>%
                            </span>
                        </div>
                    </t>
                </t>
            </t>
        </xpath>
    </t>

</templates>
