<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_pos_financial_surcharge" model="ir.ui.view">
        <field name="name">res.config.settings.form.pos.financial.surcharge</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_payment_section']" position="inside">
                <setting id="product_surcharge_id_setting"
                         title="Producto utilizado como ítem extra en la orden cuando se aplica un plan financiero con recargo o descuento."
                         string="Recargo financiero">
                    <div class="content-group">
                        <div class="row mt16">
                            <label string="Producto para recargo financiero"
                                   for="product_surcharge_id"
                                   class="col-lg-4 o_light_label"/>
                            <field name="product_surcharge_id"
                                   domain="[('available_in_pos', '=', True)]"/>
                        </div>
                        <div class="text-muted">
                            Seleccioná un producto (debe estar disponible en POS) que se
                            agregará automáticamente como línea de la orden cuando el
                            plan de cuotas elegido tenga un coeficiente distinto de 1.
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
