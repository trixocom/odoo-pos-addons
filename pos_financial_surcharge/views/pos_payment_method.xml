<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_payment_method_inherit_financial_surcharge" model="ir.ui.view">
        <field name="name">pos.payment.method.inherit.financial.surcharge</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <field name="company_id" position="after">
                <field name="available_card_ids"
                       widget="many2many_tags"
                       options="{'no_create': True}"
                       invisible="use_payment_terminal != 'financial_surcharge'"/>
            </field>
        </field>
    </record>
</odoo>
