<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
        Agrega el botón "Promo" al panel de botones de control del POS
        (dentro del grupo que se muestra en el diálogo "Más"/Acciones,
        junto a Reembolso, Lista de precios, etc.).
    -->
    <t t-name="pos_promotions.PromotionControlButton"
       t-inherit="point_of_sale.ControlButtons"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons-modal')]" position="inside">
            <button t-if="this.pos.cashier._role != 'minimal'"
                    class="o_promotion_button"
                    t-att-class="buttonClass"
                    t-on-click="() => this.clickPromotion()">
                <i class="fa fa-tags me-1" role="img" aria-label="Promoción" title="Promoción"/>
                <t t-if="currentOrder?.promotion_id" t-esc="currentOrder.promotion_id.name"/>
                <t t-else="">Promo</t>
            </button>
        </xpath>
    </t>

</templates>
