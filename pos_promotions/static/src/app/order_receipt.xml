<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
        Muestra en el ticket POS:
        - El nombre de la promoción aplicada.
        - El reintegro del banco (importe y %). Es SOLO informativo: la venta
          se cobró por el total; el reintegro lo devuelve el banco al cliente.

        Los datos vienen de propiedades JS planas seteadas en el botón Promo
        (order.promoName / promoBankPct / promoBankBase). El importe se calcula
        sobre el total real de la orden según la base configurada en la promo.
    -->
    <t t-name="pos_promotions.OrderReceiptPromotion"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('paymentlines')]" position="after">
            <t t-if="order.promoName">
                <div class="pos-receipt-promotion text-start mt-1" style="font-size: 90%;">
                    <span>
                        <i class="fa fa-tags me-1"/>
                        <strong>Promo: </strong>
                        <t t-esc="order.promoName"/>
                    </span>
                </div>
                <t t-if="order.promoBankPct">
                    <t t-set="bankBase"
                       t-value="order.promoBankBase === 'untaxed' ? order.priceExcl : order.priceIncl"/>
                    <t t-set="reintegro" t-value="bankBase * order.promoBankPct / 100"/>
                    <div class="pos-receipt-promotion-bank text-start" style="font-size: 90%;">
                        <span>
                            Reintegro banco (<t t-esc="order.promoBankPct"/>%):
                            <t t-esc="formatCurrency(reintegro)"/>
                        </span>
                    </div>
                    <div class="pos-receipt-promotion-note text-start text-muted"
                         style="font-size: 80%;">
                        <span>Reintegro a cargo del banco. No se descuenta del total.</span>
                    </div>
                </t>
            </t>
        </xpath>
    </t>

</templates>
