<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
        Muestra en el ticket POS:
        - El nombre de la promoción aplicada.
        - El reintegro del banco (importe y %). Es SOLO informativo: la venta
          se cobró por el total; el reintegro lo devuelve el banco al cliente.

        `promo` y `promoBankAmount` son getters agregados en order_receipt.js,
        que resuelven la promo desde el campo `promotion_pos_id` de la orden.
    -->
    <t t-name="pos_promotions.OrderReceiptPromotion"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('paymentlines')]" position="after">
            <t t-if="promo">
                <div class="pos-receipt-promotion text-start mt-1" style="font-size: 90%;">
                    <span>
                        <i class="fa fa-tags me-1"/>
                        <strong>Promo: </strong>
                        <t t-esc="promo.name"/>
                    </span>
                </div>
                <t t-if="promo.bank_discount_pct">
                    <div class="pos-receipt-promotion-bank text-start" style="font-size: 90%;">
                        <span>
                            Reintegro banco (<t t-esc="promo.bank_discount_pct"/>%):
                            <t t-esc="formatCurrency(promoBankAmount)"/>
                        </span>
                    </div>
                    <div class="pos-receipt-promotion-note text-start text-muted"
                         style="font-size: 80%;">
                        <span>Reintegro a cargo del banco. No se descuenta del total.</span>
                    </div>
                </t>
            </t>
        </xpath>
    </t>

</templates>
